PORT=3001
MONGODB_URI=mongodb://127.0.0.1:27017/saferide_ai

JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# OpenWeather — same key works for weather + air pollution
OPENWEATHER_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Default location when client does not send lat/lon (e.g. Bengaluru)
DEFAULT_LAT=12.9716
DEFAULT_LON=77.5946

# Delivery zone radius (km) around saved profile GPS (or default lat/lon)
DELIVERY_ZONE_RADIUS_KM=25

# Simulate curfew disruption (true/false) — triggers zero-touch claim when true
SIMULATE_CURFEW=false

# If NODE_ENV=production locally, set true to return devOtp in auth responses (default off in production)
# SHOW_DEV_OTP=true
